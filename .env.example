# Website local overrides
#
# Standard API modes are selected by npm scripts:
# - npm run dev        -> local API (http://localhost:8080)
# - npm run dev:stage  -> stage API
# - npm run dev:prod   -> production API

NEXT_PUBLIC_SHORTLINK_HOST=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Плашка «какой API подключён» в production-сборке (next start / preview без dev):
# SHOW_API_ENV_INDICATOR=true
