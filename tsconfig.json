{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@maetry/shared-dtos": [
        "./vendor/maetry-shared-dtos/src/index.ts"
      ],
      "@maetry/shared-dtos/*": [
        "./vendor/maetry-shared-dtos/src/*"
      ],
      "@maetry/shared-sdk": [
        "./vendor/maetry-shared-sdk/src/index.ts"
      ],
      "@maetry/shared-sdk/*": [
        "./vendor/maetry-shared-sdk/src/*"
      ],
      "@/public/*": [
        "./public/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/*": [
        "./src/*",
        "./*"
      ],
      "@/shared/*": [
        "./src/shared/*"
      ],
      "@/entities/*": [
        "./src/entities/*"
      ],
      "@/features/*": [
        "./src/features/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
